{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg-configuration.schema.json",
  "name": "fltx",
  "version-string": "0.1.0",
  "dependencies": [
    {
      "name": "boost-multiprecision",
      "platform": "!emscripten"
    },
    {
      "name": "mpfr",
      "platform": "!emscripten"
    },
    {
      "name": "catch2",
      "platform": "!emscripten"
    }
  ],
  "default-features": [
    {
      "name": "example-viewer",
      "platform": "!emscripten"
    }
  ],
  "features": {
    "example-viewer": {
      "description": "Build visual examples with a small SDL2 image viewer.",
      "dependencies": [
        {
          "name": "sdl2",
          "platform": "!emscripten"
        }
      ]
    }
  }
}
