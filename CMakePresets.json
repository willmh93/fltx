{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },

  "configurePresets": [
    {
      "name": "native-debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/native-debug",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
      }
    },
    {
      "name": "native-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/native-release",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
      }
    },
    {
      "name": "clang-debug",
      "displayName": "Clang Debug",
      "condition": {"type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux"},
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/clang-debug",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "${sourceDir}/cmake/toolchains/fltx-clangxx",
        "CMAKE_INSTALL_LIBDIR": "lib",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
      }
    },
    {
      "name": "clang-release",
      "displayName": "Clang Release",
      "condition": {"type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux"},
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/clang-release",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "${sourceDir}/cmake/toolchains/fltx-clangxx",
        "CMAKE_INSTALL_LIBDIR": "lib",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
      }
    },
    {
      "name": "mingw-debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/mingw-debug",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
      }
    },
    {
      "name": "mingw-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/mingw-release",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
        "VCPKG_HOST_TRIPLET": "x64-mingw-static",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
      }
    },
    {
      "name": "wasm32-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/wasm32-release",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "VCPKG_TARGET_TRIPLET": "wasm32-emscripten",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/cmake/vcpkg-ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg-triplets"
      }
    },
    {
      "name": "vs2026",
      "condition": {"type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows"},
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/vs2026",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/macos-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      }
    }
  ],

  "buildPresets": [
    { "name": "01. native-debug",     "configurePreset": "native-debug" },
    { "name": "02. native-release",   "configurePreset": "native-release" },
    { "name": "03. mingw-debug",      "configurePreset": "mingw-debug" },
    { "name": "04. mingw-release",    "configurePreset": "mingw-release" },
    { "name": "05. wasm32-release",   "configurePreset": "wasm32-release" },
    { "name": "06. macos-release",    "configurePreset": "macos-release" },
    { "name": "clang-debug",          "configurePreset": "clang-debug" },
    { "name": "clang-release",        "configurePreset": "clang-release" }
  ]
}
